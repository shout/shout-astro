---
import AstroshipLayout from "../layouts/AstroshipLayout.astro";
import Container from "../components/container.astro";
import PricingCard from "../components/pricing-card.astro";
import Cta from "../components/cta.astro";
---

<AstroshipLayout title="Pricing - Shout.com">
  <Container>
    <div class="text-center pt-12 pb-8">
      <h1 class="text-4xl lg:text-5xl font-bold lg:tracking-tight">Simple, Transparent Pricing</h1>
      <p class="text-lg mt-4 text-gray-500">Choose the perfect plan for your needs. Always flexible to scale up or down.</p>
    </div>

    <div class="flex justify-end mb-4 max-w-screen-lg mx-auto">
      <div class="inline-flex items-center bg-gray-100 rounded-full p-1" id="billing-toggle">
        <button class="px-4 py-1.5 text-sm font-medium rounded-full transition-colors bg-white text-gray-900 shadow-sm cursor-pointer" data-period="annual">Yearly (save 44%)</button>
        <button class="px-4 py-1.5 text-sm font-medium rounded-full transition-colors text-gray-500 hover:text-gray-700 cursor-pointer" data-period="monthly">Monthly</button>
        <button class="px-4 py-1.5 text-sm font-medium rounded-full transition-colors text-gray-500 hover:text-gray-700 cursor-pointer" data-period="student">Student & Non-profit</button>
      </div>
    </div>

    <div id="paid-plans" class="rounded-3xl p-6 pt-5 bg-white shadow-lg border border-gray-200 max-w-screen-lg mx-auto">
      <div class="grid md:grid-cols-3 md:divide-x md:divide-gray-100 gap-5">
        <PricingCard
          name="Essentials"
          description="Remove limits and add your branding"
          price="12.99"
          monthlyPrice="20"
          period="/month"
          billingNote="billed annually"
          billingNoteMonthly="billed monthly"
          topFeatures={["Unlimited responses", "1 user", "Your logo and brand", "100MB file uploads", "Low AI usage", "Cross-tabulation"]}
          topFeatureIcons={["bx:infinite", "bx:user", "bx:star", "bx:cloud-upload", "bx:bxs-brain", "bx:bar-chart-alt-2"]}
          topFeatureTooltips={["", "", "", "", "", "Compare answers across different questions to uncover patterns and insights — for example, product interest broken down by age group and location."]}
          topFeatureDisabled={[false, false, false, false, false, true]}
          accordions={[
            {
              icon: "bx:file",
              title: "Forms & quizzes",
              description: "Unlock unlimited collection",
              items: [
                { icon: "bx:time", text: "No collection time limits" },
                { icon: "bx:transfer", text: "Partial submissions", tooltip: "Capture responses from people who started your form but didn't finish. Any page or section they completed is saved, so you don't lose valuable data." },
                { icon: "bx:help-circle", text: "Quiz scoring" },
                { icon: "bx:download", text: "Excel & PDF export" },
              ]
            },
            {
              icon: "bx:group",
              title: "Contacts",
              badge: "10,000 contacts",
              description: "Know everything about every contact — forms, conversations, and notes",
              items: [
                { icon: "bx:user-plus", text: "Forms → contacts", tooltip: "Every form response automatically creates or updates a contact. Link questions to contact fields like name, email, or company to build your database as you collect responses." },
                { icon: "bx:edit", text: "Prefill forms", tooltip: "When a known contact opens your form, their details are filled in automatically — saving them time and improving completion rates." },
                { icon: "bx:filter", text: "Lists & segments", tooltip: "Lists help you organise contacts and manage consent — like email marketing opt-ins. Segments are saved filters that automatically group contacts by their attributes or activity." },
                { icon: "bx:envelope", text: "Email survey invitations" },
              ]
            },
            {
              icon: "bx:bxs-inbox",
              title: "Inbox",
              badge: "Coming soon",
              description: "Respond directly to feedback and leads with a unified inbox",
              items: [
                { icon: "bx:log-in", text: "Unified inbox", tooltip: "Keep form submissions, customer enquiries, and support messages out of your personal email. Everything customer-facing lives in one dedicated place — so nothing gets lost and your private inbox stays clean." },
                { icon: "bx:reply", text: "Reply to respondents", tooltip: "Reply to anyone who submits a form, directly from your inbox. Connect your Gmail or Outlook account to send from your own company email address." },
                { icon: "bx:at", text: "Connect email accounts", tooltip: "Forward emails from sales@, support@, or any address into your inbox. Send replies via your connected Gmail or Outlook account." },
                { icon: "bx:chat", text: "Social messaging" },
              ]
            }
          ]}
          seeAllLabel="See all features"
          seeAllLink="#compare-plans"
        />
        <PricingCard
          name="Plus"
          description="Analytics, payments and collaboration"
          price="25"
          monthlyPrice="45"
          period="/month"
          billingNote="billed annually"
          billingNoteMonthly="billed monthly"
          topFeatures={["Unlimited responses", "3 users", "No Shout branding", "1GB file uploads", "Medium AI usage", "Cross-tabulation"]}
          topFeatureIcons={["bx:infinite", "bx:bxs-group", "bx:bxs-star-half", "bx:cloud-upload", "bx:bxs-brain", "bx:bar-chart-alt-2"]}
          topFeatureTooltips={["", "", "", "", "", "Compare answers across different questions to uncover patterns and insights — for example, product interest broken down by age group and location."]}
          popular={true}
          accordions={[
            {
              icon: "bx:file",
              title: "Forms & quizzes",
              description: "Everything in Essentials, and...",
              items: [
                { icon: "bx:calculator", text: "3 calculators" },
                { icon: "bx:credit-card", text: "Stripe payments" },
                { icon: "bx:edit", text: "Collaborative editing" },
                { icon: "bx:map", text: "Address autofill (UK/US)" },
                { icon: "bx:link-external", text: "Survey redirection" },
                { icon: "bx:transfer", text: "Text & answer piping" },
                { icon: "bx:git-compare", text: "A/B testing" },
              ]
            },
            {
              icon: "bx:group",
              title: "Contacts",
              badge: "25,000 contacts",
              description: "Know everything about every contact — forms, conversations, and notes",
              items: [
                { icon: "bx:user-plus", text: "Forms → contacts", tooltip: "Every form response automatically creates or updates a contact. Link questions to contact fields like name, email, or company to build your database as you collect responses." },
                { icon: "bx:edit", text: "Prefill forms", tooltip: "When a known contact opens your form, their details are filled in automatically — saving them time and improving completion rates." },
                { icon: "bx:filter", text: "Lists & segments", tooltip: "Lists help you organise contacts and manage consent — like email marketing opt-ins. Segments are saved filters that automatically group contacts by their attributes or activity." },
                { icon: "bx:envelope", text: "Email survey invitations" },
              ]
            },
            {
              icon: "bx:bxs-inbox",
              title: "Inbox",
              badge: "Coming soon",
              description: "Respond to feedback and leads as a team with a shared inbox",
              items: [
                { icon: "bx:log-in", text: "Shared team inbox", tooltip: "A shared workspace for your whole team to manage form responses, customer enquiries, and support messages — separate from everyone's personal email. See who's handling what, so nothing falls through the cracks." },
                { icon: "bx:reply", text: "Reply to respondents", tooltip: "Reply to anyone who submits a form, directly from your inbox. Connect your Gmail or Outlook account to send from your own company email address." },
                { icon: "bx:user-check", text: "Assignment & routing", tooltip: "Assign conversations to team members and route incoming messages to the right person automatically." },
                { icon: "bx:at", text: "Connect email accounts", tooltip: "Forward emails from sales@, support@, or any address into your inbox. Send replies via your connected Gmail or Outlook account." },
                { icon: "bx:chat", text: "Social messaging" },
              ]
            }
          ]}
          seeAllLabel="See all features"
          seeAllLink="#compare-plans"
        />
        <PricingCard
          name="Business"
          description="White-label with custom domains and support"
          price="59"
          monthlyPrice="99"
          period="/month"
          billingNote="billed annually"
          billingNoteMonthly="billed monthly"
          topFeatures={["Unlimited responses", "5 users", "Use your domain", "10GB file uploads", "High AI usage", "Cross-tabulation"]}
          topFeatureIcons={["bx:infinite", "bx:bxs-group", "bx:bxs-star", "bx:cloud-upload", "bx:bxs-brain", "bx:bar-chart-alt-2"]}
          topFeatureTooltips={["", "", "", "", "", "Compare answers across different questions to uncover patterns and insights — for example, product interest broken down by age group and location."]}
          accordions={[
            {
              icon: "bx:file",
              title: "Forms & quizzes",
              description: "Everything in Plus, and...",
              items: [
                { icon: "bx:calculator", text: "Unlimited calculators" },
                { icon: "bx:support", text: "Priority support" },
                { icon: "bx:link", text: "Custom URL slug" },
                { icon: "bx:money", text: "Purchase order / wire payments" },
                { icon: "bx:user-plus", text: "Additional seats available" },
                { icon: "bx:star", text: "Higher AI limits" },
              ]
            },
            {
              icon: "bx:group",
              title: "Contacts",
              badge: "50,000 contacts",
              description: "Know everything about every contact — forms, conversations, and notes",
              items: [
                { icon: "bx:user-plus", text: "Forms → contacts", tooltip: "Every form response automatically creates or updates a contact. Link questions to contact fields like name, email, or company to build your database as you collect responses." },
                { icon: "bx:edit", text: "Prefill forms", tooltip: "When a known contact opens your form, their details are filled in automatically — saving them time and improving completion rates." },
                { icon: "bx:filter", text: "Lists & segments", tooltip: "Lists help you organise contacts and manage consent — like email marketing opt-ins. Segments are saved filters that automatically group contacts by their attributes or activity." },
                { icon: "bx:envelope", text: "Email survey invitations" },
              ]
            },
            {
              icon: "bx:bxs-inbox",
              title: "Inbox",
              badge: "Coming soon",
              description: "Respond to feedback and leads as a team with a shared inbox",
              items: [
                { icon: "bx:log-in", text: "Shared team inbox", tooltip: "A shared workspace for your whole team to manage form responses, customer enquiries, and support messages — separate from everyone's personal email. See who's handling what, so nothing falls through the cracks." },
                { icon: "bx:reply", text: "Reply to respondents", tooltip: "Reply to anyone who submits a form, directly from your inbox. Connect your Gmail or Outlook account to send from your own company email address." },
                { icon: "bx:user-check", text: "Assignment & routing", tooltip: "Assign conversations to team members and route incoming messages to the right person automatically." },
                { icon: "bx:at", text: "Connect email accounts", tooltip: "Forward emails from sales@, support@, or any address into your inbox. Send replies via your connected Gmail or Outlook account." },
                { icon: "bx:chat", text: "Social messaging" },
              ]
            }
          ]}
          seeAllLabel="See all features"
          seeAllLink="#compare-plans"
        />
      </div>
      <!-- CTA -->
      <div class="mt-6 text-center">
        <a
          href="https://identity.shout.com/Account/Register"
          class="inline-block px-10 py-3 rounded-lg text-sm font-semibold transition-colors bg-[#FB7258] text-white hover:bg-[#e5603d] shadow-sm">
          Start your free trial
        </a>
        <p class="mt-2 text-sm text-gray-400">All paid trials include full Plus features for 14 days. No credit card required.</p>
      </div>
    </div>

    <!-- Student & Non-profit plans (hidden by default) -->
    <div id="student-plans" class="rounded-3xl p-6 pt-5 bg-white shadow-lg border border-gray-200 max-w-3xl mx-auto hidden">
      <div class="grid md:grid-cols-2 md:divide-x md:divide-gray-100 gap-5">
        <PricingCard
          name="Student"
          description="Verified students get Essentials features at a reduced price"
          price="2.99"
          period="/month"
          billingNote="billed annually · or £7.99/mo monthly"
          topFeatures={["Unlimited responses", "1 user", "Your logo and brand", "100MB file uploads", "Low AI usage", "Cross-tabulation"]}
          topFeatureIcons={["bx:infinite", "bx:user", "bx:star", "bx:cloud-upload", "bx:bxs-brain", "bx:bar-chart-alt-2"]}
          topFeatureTooltips={["", "", "", "", "", "Compare answers across different questions to uncover patterns and insights — for example, product interest broken down by age group and location."]}
          includes="All Essentials features"
          seeAllLabel="See all features"
          seeAllLink="#compare-plans"
        />
        <PricingCard
          name="Schools & Non-profit"
          description="Registered schools and non-profits get Plus features at a reduced price"
          price="12.99"
          period="/month"
          billingNote="billed annually"
          topFeatures={["Unlimited responses", "3 users", "No Shout branding", "1GB file uploads", "Medium AI usage", "Cross-tabulation"]}
          topFeatureIcons={["bx:infinite", "bx:bxs-group", "bx:bxs-star-half", "bx:cloud-upload", "bx:bxs-brain", "bx:bar-chart-alt-2"]}
          topFeatureTooltips={["", "", "", "", "", "Compare answers across different questions to uncover patterns and insights — for example, product interest broken down by age group and location."]}
          includes="All Plus features"
          seeAllLabel="See all features"
          seeAllLink="#compare-plans"
        />
      </div>
      <div class="mt-6 text-center">
        <a
          href="https://identity.shout.com/Account/Register"
          class="inline-block px-10 py-3 rounded-lg text-sm font-semibold transition-colors bg-[#FB7258] text-white hover:bg-[#e5603d] shadow-sm">
          Start your free trial
        </a>
        <p class="mt-2 text-sm text-gray-400">All paid trials include full Plus features for 14 days. No credit card required.</p>
      </div>
    </div>

    <script>
      const paid = document.getElementById('paid-plans');
      if (paid) {
        let activeIdx: string | null = null;
        paid.addEventListener('mouseover', (e) => {
          const row = (e.target as HTMLElement).closest('.top-feature-row') as HTMLElement | null;
          const idx = row?.dataset.topRow ?? null;
          if (idx === activeIdx) return;
          if (activeIdx !== null) {
            paid.querySelectorAll(`.top-feature-row[data-top-row="${activeIdx}"]`).forEach(el => el.classList.remove('bg-gray-50'));
          }
          activeIdx = idx;
          if (idx !== null) {
            paid.querySelectorAll(`.top-feature-row[data-top-row="${idx}"]`).forEach(el => el.classList.add('bg-gray-50'));
          }
        });
        paid.addEventListener('mouseleave', () => {
          if (activeIdx !== null) {
            paid.querySelectorAll(`.top-feature-row[data-top-row="${activeIdx}"]`).forEach(el => el.classList.remove('bg-gray-50'));
            activeIdx = null;
          }
        });

        // Accordion sync: one section open at a time, synced across plans
        paid.addEventListener('click', (e) => {
          const summary = (e.target as HTMLElement).closest('summary');
          if (!summary) return;
          const det = summary.parentElement as HTMLDetailsElement;
          if (!det?.dataset?.accordionIdx) return;
          e.preventDefault();
          const idx = det.dataset.accordionIdx;
          const willOpen = !det.open;
          paid.querySelectorAll<HTMLDetailsElement>('details[data-accordion-idx]').forEach(el => {
            el.open = willOpen && el.dataset.accordionIdx === idx;
          });
        });
      }

      // Billing toggle
      const toggle = document.getElementById('billing-toggle');
      const studentPlans = document.getElementById('student-plans');
      if (toggle) {
        const buttons = toggle.querySelectorAll('button');
        buttons.forEach(btn => {
          btn.addEventListener('click', () => {
            const period = btn.dataset.period;
            const isAnnual = period === 'annual';
            const isStudent = period === 'student';
            buttons.forEach(b => {
              if (b.dataset.period === period) {
                b.classList.add('bg-white', 'text-gray-900', 'shadow-sm');
                b.classList.remove('text-gray-500', 'hover:text-gray-700');
              } else {
                b.classList.remove('bg-white', 'text-gray-900', 'shadow-sm');
                b.classList.add('text-gray-500', 'hover:text-gray-700');
              }
            });
            // Show/hide plan containers
            if (isStudent) {
              paid?.classList.add('hidden');
              studentPlans?.classList.remove('hidden');
            } else {
              paid?.classList.remove('hidden');
              studentPlans?.classList.add('hidden');
              // Swap prices for monthly/annual
              paid?.querySelectorAll('[data-annual-price]').forEach(el => {
                const priceSpan = el.querySelector('.plan-price');
                if (priceSpan) {
                  priceSpan.textContent = isAnnual ? el.dataset.annualPrice! : el.dataset.monthlyPrice!;
                }
              });
              paid?.querySelectorAll('.billing-note').forEach(el => {
                const note = el as HTMLElement;
                note.textContent = isAnnual ? note.dataset.annualNote! : note.dataset.monthlyNote!;
              });
              paid?.querySelectorAll('.special-price').forEach(el => {
                const link = el as HTMLElement;
                const textSpan = link.querySelector('.special-price-text');
                if (textSpan) {
                  textSpan.textContent = isAnnual ? link.dataset.annualLabel! : link.dataset.monthlyLabel!;
                }
              });
            }
          });
        });
      }
    </script>

    <Cta />

    <!-- FAQ Section -->
    <div class="mt-24">
      <h2 class="text-3xl lg:text-4xl font-bold text-center mb-12">
        Frequently Asked Questions
      </h2>

      <div class="max-w-3xl mx-auto space-y-8">
        <div>
          <h3 class="text-xl font-semibold mb-2">Can I change plans anytime?</h3>
          <p class="text-gray-600">
            Yes, you can upgrade or downgrade your plan at any time. Changes will be reflected in your next billing cycle.
          </p>
        </div>

        <div>
          <h3 class="text-xl font-semibold mb-2">How does the free trial work?</h3>
          <p class="text-gray-600">
            All plans include a 14-day free trial with full access to all features. No credit card required to start.
          </p>
        </div>

        <div>
          <h3 class="text-xl font-semibold mb-2">What happens to my data if I cancel?</h3>
          <p class="text-gray-600">
            Your data remains accessible for 30 days after cancellation. You can export all your data at any time.
          </p>
        </div>

        <div>
          <h3 class="text-xl font-semibold mb-2">Do you offer discounts for non-profits?</h3>
          <p class="text-gray-600">
            Yes, we offer special pricing for registered non-profit organizations. Contact our sales team for details.
          </p>
        </div>
      </div>
    </div>

    <!-- Feature Comparison Table -->
    <div id="compare-plans" class="mt-24 mb-24">
      <h2 class="text-3xl lg:text-4xl font-bold text-center mb-4">
        Compare Plans
      </h2>
      <p class="text-center text-gray-500 mb-12 max-w-2xl mx-auto">A detailed look at what's included in each plan.</p>

      <div class="max-w-screen-lg mx-auto bg-white rounded-3xl p-6 md:p-10 shadow-sm">
        <!-- Plan column headers -->
        <div class="hidden md:grid grid-cols-[2fr_1fr_1fr_1fr] gap-2 mb-6 px-4">
          <div></div>
          <div class="text-center text-sm font-semibold text-gray-900">Essentials</div>
          <div class="text-center text-sm font-semibold text-gray-900">Plus</div>
          <div class="text-center text-sm font-semibold text-gray-900">Business</div>
        </div>

        <!-- Basic Usage -->
        <details class="group mb-4" open>
          <summary class="flex items-center justify-between cursor-pointer mb-1 px-4 py-2 rounded-lg hover:bg-gray-50 select-none">
            <h3 class="text-lg font-bold text-gray-900">Basic Usage</h3>
            <svg class="w-5 h-5 text-gray-400 transition-transform duration-200 group-open:rotate-180" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" /></svg>
          </summary>
          <div class="space-y-0">
            <div class="grid grid-cols-[2fr_1fr_1fr_1fr] gap-2 px-4 py-3 rounded-lg bg-gray-50/70">
              <span class="text-sm text-gray-700">Surveys, Forms & Quizzes</span>
              <span class="text-sm text-gray-500 text-center">Unlimited</span>
              <span class="text-sm text-gray-500 text-center">Unlimited</span>
              <span class="text-sm text-gray-500 text-center">Unlimited</span>
            </div>
            <div class="grid grid-cols-[2fr_1fr_1fr_1fr] gap-2 px-4 py-3">
              <span class="text-sm text-gray-700">Calculators</span>
              <span class="text-sm text-gray-400 text-center">—</span>
              <span class="text-sm text-gray-500 text-center">3</span>
              <span class="text-sm text-gray-500 text-center">Unlimited</span>
            </div>
            <div class="grid grid-cols-[2fr_1fr_1fr_1fr] gap-2 px-4 py-3 rounded-lg bg-gray-50/70">
              <span class="text-sm text-gray-700">Form responses</span>
              <span class="text-sm text-gray-500 text-center">Unlimited</span>
              <span class="text-sm text-gray-500 text-center">Unlimited</span>
              <span class="text-sm text-gray-500 text-center">Unlimited</span>
            </div>
            <div class="grid grid-cols-[2fr_1fr_1fr_1fr] gap-2 px-4 py-3">
              <span class="text-sm text-gray-700">Contacts</span>
              <span class="text-sm text-gray-500 text-center">10,000</span>
              <span class="text-sm text-gray-500 text-center">25,000</span>
              <span class="text-sm text-gray-500 text-center">50,000</span>
            </div>
            <div class="grid grid-cols-[2fr_1fr_1fr_1fr] gap-2 px-4 py-3 rounded-lg bg-gray-50/70">
              <span class="text-sm text-gray-700">Users</span>
              <span class="text-sm text-gray-500 text-center">1</span>
              <span class="text-sm text-gray-500 text-center">3</span>
              <span class="text-sm text-gray-500 text-center">5</span>
            </div>
            <div class="grid grid-cols-[2fr_1fr_1fr_1fr] gap-2 px-4 py-3">
              <span class="text-sm text-gray-700">File upload</span>
              <span class="text-sm text-gray-500 text-center">100MB</span>
              <span class="text-sm text-gray-500 text-center">1GB</span>
              <span class="text-sm text-gray-500 text-center">10GB</span>
            </div>
            <div class="grid grid-cols-[2fr_1fr_1fr_1fr] gap-2 px-4 py-3 rounded-lg bg-gray-50/70">
              <span class="text-sm text-gray-700">Stripe payments</span>
              <span class="text-sm text-gray-400 text-center">—</span>
              <span class="text-sm text-[#FB7258] text-center">✔</span>
              <span class="text-sm text-[#FB7258] text-center">✔</span>
            </div>
            <div class="grid grid-cols-[2fr_1fr_1fr_1fr] gap-2 px-4 py-3">
              <span class="text-sm text-gray-700">Collection time limit</span>
              <span class="text-sm text-gray-500 text-center">Unlimited</span>
              <span class="text-sm text-gray-500 text-center">Unlimited</span>
              <span class="text-sm text-gray-500 text-center">Unlimited</span>
            </div>
            <div class="grid grid-cols-[2fr_1fr_1fr_1fr] gap-2 px-4 py-3 rounded-lg bg-gray-50/70">
              <span class="text-sm text-gray-700">Partial submissions</span>
              <span class="text-sm text-[#FB7258] text-center">✔</span>
              <span class="text-sm text-[#FB7258] text-center">✔</span>
              <span class="text-sm text-[#FB7258] text-center">✔</span>
            </div>
            <div class="grid grid-cols-[2fr_1fr_1fr_1fr] gap-2 px-4 py-3">
              <span class="text-sm text-gray-700">AI generation</span>
              <span class="text-sm text-gray-500 text-center">Low</span>
              <span class="text-sm text-gray-500 text-center">Medium</span>
              <span class="text-sm text-gray-500 text-center">High</span>
            </div>
          </div>
        </details>

        <!-- Form Builder -->
        <details class="group mb-4">
          <summary class="flex items-center justify-between cursor-pointer mb-1 px-4 py-2 rounded-lg hover:bg-gray-50 select-none">
            <h3 class="text-lg font-bold text-gray-900">Form Builder</h3>
            <svg class="w-5 h-5 text-gray-400 transition-transform duration-200 group-open:rotate-180" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" /></svg>
