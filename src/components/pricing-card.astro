---
import { Icon } from "astro-icon/components";

export interface Props {
  name: string;
  description?: string;
  price: string;
  monthlyPrice?: string;
  period: string;
  billingNote?: string;
  billingNoteMonthly?: string;
  topFeatures?: string[];
  topFeatureIcons?: string[];
  topFeatureTooltips?: string[];
  topFeatureDisabled?: boolean[];
  includes?: string;
  features?: string[];
  featureIcons?: string[];
  accordions?: {
    icon: string;
    title: string;
    badge?: string;
    description: string;
    items: { icon: string; text: string; tooltip?: string }[];
  }[];
  popular?: boolean;
  popularLabel?: string;
  ctaStyle?: "solid" | "outline";
  ctaText?: string;
  ctaLink?: string;
  trialLabel?: string;
  specialPriceLabel?: string;
  specialPriceLabelMonthly?: string;
  specialPriceLink?: string;
  seeAllLabel?: string;
  seeAllLink?: string;
}

const {
  name,
  description,
  price,
  monthlyPrice,
  period,
  billingNote,
  billingNoteMonthly,
  topFeatures = [],
  topFeatureIcons = [],
  topFeatureTooltips = [],
  topFeatureDisabled = [],
  includes,
  features = [],
  featureIcons = [],
  accordions,
  popular = false,
  popularLabel = "Most Popular",
  ctaStyle = "solid",
  ctaText = "Get Started",
  ctaLink = "#",
  trialLabel,
  specialPriceLabel,
  specialPriceLabelMonthly,
  specialPriceLink,
  seeAllLabel,
  seeAllLink,
} = Astro.props;

const buttonLabel = trialLabel ? `${ctaText} — ${trialLabel}` : ctaText;
---

<div class:list={["relative", popular && "lg:-my-4 lg:z-10"]}>
  {popular && (
    <div class="absolute -top-4 left-1/2 -translate-x-1/2 z-10">
      <span class="text-sm font-medium px-4 py-1 rounded-full whitespace-nowrap bg-[#FB7258] text-white">
        {popularLabel}
      </span>
    </div>
  )}
  <div
    class:list={[
      "flex flex-col w-full py-5 px-4 h-full",
      popular
        ? "lg:py-8"
        : ""
    ]}>
    <div class="text-center">
      <h4 class="text-lg font-bold text-gray-900">{name}</h4>
      {description && (
        <p class="mt-1 text-sm text-gray-500 min-h-[2.5rem]">{description}</p>
      )}
      <p class="mt-3 text-3xl font-bold text-gray-900" data-annual-price={price} data-monthly-price={monthlyPrice || price}>
        {!/^\d/.test(price) ? "" : <span class="currency-symbol">£</span>}<span class="plan-price">{price}</span>
        <span class="text-sm font-normal text-gray-400">{period}</span>
      </p>
      {billingNote && (
        <p class="mt-1 text-sm text-gray-400 billing-note" data-annual-note={billingNote} data-monthly-note={billingNoteMonthly || billingNote}>{billingNote}</p>
      )}
      {specialPriceLabel && (
        <a href={specialPriceLink || "#"} class="mt-1 inline-block text-sm text-gray-400 hover:text-gray-600 transition-colors special-price" data-annual-label={specialPriceLabel} data-monthly-label={specialPriceLabelMonthly || specialPriceLabel}>
          <span class="special-price-text">{specialPriceLabel}</span> &rarr;
        </a>
      )}
      <div class="mt-4 border-t border-gray-100"></div>
    </div>
    {ctaLink !== "#" && (
      <a
        href={ctaLink}
        class:list={[
          "mt-4 block w-full text-center px-4 py-2.5 rounded-lg text-sm font-medium transition-colors",
          ctaStyle === "solid"
            ? "bg-[#FB7258] text-white hover:bg-[#e5603d]"
            : "border-2 border-gray-300 text-gray-500 hover:border-gray-400 hover:text-gray-700",
        ]}>
        {buttonLabel}
      </a>
    )}
    <div class="flex flex-col flex-1 mt-6 -mx-4">
      <ul class="grid content-start text-left">
        {topFeatures.map((item, idx) => (
          <li class:list={["flex items-start gap-3 text-base px-4 py-2.5 rounded-lg transition-colors cursor-default top-feature-row", topFeatureDisabled[idx] ? "text-gray-400 line-through" : "text-gray-700", topFeatureTooltips[idx] && "group/tip relative cursor-help"]} data-top-row={idx}>
            <Icon
              name={topFeatureIcons[idx] || "bx:check"}
              class:list={["w-5 h-5 flex-shrink-0 mt-0.5", topFeatureDisabled[idx] ? "text-gray-300" : "text-[#FB7258]"]}
            />
            <span class="flex-1">{item}</span>
            {topFeatureTooltips[idx] && (
              <>
                <Icon name="bx:info-circle" class="w-4 h-4 text-gray-300 flex-shrink-0 mt-0.5" />
                <span class="pricing-tooltip">{topFeatureTooltips[idx]}</span>
              </>
            )}
          </li>
        ))}
      </ul>
      {accordions ? (
        <div class="mt-2 border-t border-gray-100 pt-1">
          {accordions.map((section, idx) => (
            <details class="group" data-accordion-idx={idx}>
              <summary class="flex items-center gap-2 cursor-pointer py-2.5 px-4 hover:bg-gray-50 rounded-lg select-none">
                <Icon name={section.icon} class="w-5 h-5 text-[#FB7258] flex-shrink-0" />
                <span class="text-sm font-semibold text-gray-700 flex-1">{section.title}</span>
                {section.badge && (
                  <span class="text-sm bg-gray-100 text-gray-500 px-2 py-0.5 rounded-full whitespace-nowrap">{section.badge}</span>
                )}
                <Icon name="bx:chevron-down" class="w-4 h-4 text-gray-400 transition-transform duration-200 group-open:rotate-180 flex-shrink-0" />
              </summary>
              <p class="text-sm text-gray-500 bg-gray-50 rounded-md px-3 py-2 mb-1 mx-4">{section.description}</p>
              <ul class="pb-3 px-4 ml-7">
                {section.items.map((item) => (
                  <li class:list={["flex items-center gap-2 text-sm text-gray-600 py-1", item.tooltip && "group/tip relative cursor-help"]}>
                    <Icon name={item.icon} class="w-4 h-4 text-[#FB7258] flex-shrink-0" />
                    <span class="flex-1">{item.text}</span>
                    {item.tooltip && (
                      <>
                        <Icon name="bx:info-circle" class="w-3.5 h-3.5 text-gray-300 flex-shrink-0" />
                        <span class="pricing-tooltip">{item.tooltip}</span>
                      </>
                    )}
                  </li>
                ))}
              </ul>
            </details>
          ))}
        </div>
      ) : (
        <ul class="grid content-start text-left">
          {includes ? (
            <li class="flex items-start gap-3 text-base text-gray-600 pt-4 mt-2 px-4 border-t border-gray-100">
              <Icon name="bx:check-double" class="w-5 h-5 flex-shrink-0 mt-0.5 text-[#FB7258]" />
              <span class="font-semibold">{includes}</span>
            </li>
          ) : topFeatures.length > 0 && features.length > 0 ? (
            <li class="border-t border-gray-100 pt-3 mt-2 -mb-1"></li>
          ) : null}
          {features.map((item, idx) => (
            <li class="flex items-start gap-3 text-base text-gray-700 px-4 py-2.5">
              <Icon
                name={featureIcons[idx] || "bx:check"}
                class="w-5 h-5 flex-shrink-0 mt-0.5 text-[#FB7258]"
              />
              <span>{item}</span>
            </li>
          ))}
        </ul>
      )}
    </div>
    {seeAllLabel && seeAllLink && (
      <a href={seeAllLink} class="mt-5 text-sm text-gray-400 hover:text-[#FB7258] transition-colors text-center">
        {seeAllLabel} &rarr;
      </a>
    )}
  </div>
</div>

<style>
  .pricing-tooltip {
    display: none;
    position: absolute;
    top: 50%;
    left: 100%;
    transform: translateY(-50%);
    margin-left: 0.5rem;
    width: 14rem;
    z-index: 50;
    padding: 0.5rem 0.75rem;
    font-size: 0.875rem;
    line-height: 1.4;
    color: #fff;
    background: #1e293b;
    border-radius: 0.5rem;
    pointer-events: none;
  }
  .group\/tip:hover .pricing-tooltip {
    display: block;
  }
</style>
